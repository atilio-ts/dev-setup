{
  "cleanupPeriodDays": 99999,
  "env": {
    "NO_UPDATE_NOTIFIER": "1",
    "CLAUDE_CODE_MAX_THINKING_TOKENS": "10000",
    "MAX_MCP_OUTPUT_TOKENS": "8192"
  },
  "permissions": {
    "allow": [
      "mcp__filestash__stash_clear",
      "mcp__filestash__stash_status",
      "mcp__filestash__read_file",
      "mcp__filestash__read_files",
      "mcp__houtini-lm__chat",
      "mcp__houtini-lm__code_task",
      "mcp__houtini-lm__code_task_files",
      "mcp__houtini-lm__custom_prompt",
      "mcp__houtini-lm__discover",
      "mcp__houtini-lm__embed",
      "mcp__houtini-lm__list_models",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(which *)",
      "Bash(bat *)",
      "Bash(eza *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git remote*)",
      "Bash(curl *)"
    ],
    "deny": [
      "Read($HOME/.ssh/**)",
      "Read($HOME/.aws/**)",
      "Read(**/.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push*--force-with-lease*)",
      "Bash(git rebase -i*)",
      "Bash(git rebase*--onto*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git commit*--amend*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",
      "Bash(git clean -f*)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git checkout*--*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git tag -d*)",
      "Bash(git push*--delete*)",
      "Bash(git push*--prune*)",
      "Bash(git remote remove*)",
      "Bash(git remote rm*)",
      "Bash(git config --global*)",
      "Bash(git config --system*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(dd if=*)",
      "Bash(dd of=*)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)",
      "Bash(chown root*)",
      "Bash(chown -R root*)",
      "Bash(sudo chmod*)",
      "Bash(sudo chown*)",
      "Bash(kill -9*)",
      "Bash(kill -KILL*)",
      "Bash(pkill*)",
      "Bash(killall*)",
      "Bash(npm publish*)",
      "Bash(pip publish*)",
      "Bash(twine upload*)",
      "Bash(cargo publish*)",
      "Bash(gem push*)",
      "Bash(sudo rm*)",
      "Bash(sudo su*)",
      "Bash(sudo -i*)",
      "Bash(sudo bash*)",
      "Bash(sudo sh*)",
      "Bash(shred*)",
      "Bash(wipe *)",
      "Bash(mkfs*)",
      "Bash(truncate *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"pre:compact\" \"scripts/hooks/pre-compact.js\" \"standard,strict\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-websearch.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/plugins/marketplaces/everything-claude-code/skills/strategic-compact/suggest-compact.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/plugins/marketplaces/everything-claude-code/skills/strategic-compact/suggest-compact.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"session:end:marker\" \"scripts/hooks/session-end-marker.js\" \"minimal,standard,strict\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'input=$(cat); for root in \"${CLAUDE_PLUGIN_ROOT:-}\" \"$HOME/.claude/plugins/everything-claude-code\" \"$HOME/.claude/plugins/everything-claude-code@everything-claude-code\" \"$HOME/.claude/plugins/marketplace/everything-claude-code\"; do if [ -n \"$root\" ] \u0026\u0026 [ -f \"$root/scripts/hooks/run-with-flags.js\" ]; then printf \"%s\" \"$input\" | node \"$root/scripts/hooks/run-with-flags.js\" \"session:start\" \"scripts/hooks/session-start.js\" \"minimal,standard,strict\"; exit $?; fi; done; for parent in \"$HOME/.claude/plugins\" \"$HOME/.claude/plugins/marketplace\"; do if [ -d \"$parent\" ]; then candidate=$(find \"$parent\" -maxdepth 2 -type f -path \"*/scripts/hooks/run-with-flags.js\" 2\u003e/dev/null | head -n 1); if [ -n \"$candidate\" ]; then root=$(dirname \"$(dirname \"$(dirname \"$candidate\")\")\"); printf \"%s\" \"$input\" | node \"$root/scripts/hooks/run-with-flags.js\" \"session:start\" \"scripts/hooks/session-start.js\" \"minimal,standard,strict\"; exit $?; fi; fi; done; echo \"[SessionStart] WARNING: could not resolve ECC plugin root; skipping session-start hook\" \u003e\u00262; printf \"%s\" \"$input\"; exit 0'",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "fullstack-dev-skills@fullstack-dev-skills": true,
    "coderabbit@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "token-optimizer@alexgreensh-token-optimizer": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "fullstack-dev-skills": {
      "source": {
        "source": "github",
        "repo": "jeffallan/claude-skills"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "alexgreensh-token-optimizer": {
      "source": {
        "source": "github",
        "repo": "alexgreensh/token-optimizer"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "stable"
}
